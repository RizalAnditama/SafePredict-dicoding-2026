# Example environment variables for the backend
# Copy this file to `.env` during development and fill values.

# Database (example MongoDB Atlas or SQL URL)
DB_CONNECTION_URL=sqlite:///./safepredict.db
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/safepredict?retryWrites=true&w=majority

# Azure storage (optional)
AZURE_STORAGE_CONNSTRING=

# YOLO weights path (if using local weights)
YOLO_WEIGHTS_PATH=weights/yolov8s.pt

# App settings
LOG_LEVEL=INFO
SECRET_KEY=change-me
